ARG UBUNTU_VERSION=22.04
FROM ubuntu:${UBUNTU_VERSION}

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    perl \
    curl \
    lsb-release \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /plugin

# The project root is mounted at /plugin at runtime — nothing is baked in.
# Entry point is set by the host build script.
